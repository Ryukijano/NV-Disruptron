# NV-Disruptron — optional environment overrides

cp .env.example .env

# Required for voice alerts (hackathon sponsor)
ELEVENLABS_API_KEY=

# Optional voice selection (defaults via disruptron configure)
# ELEVENLABS_VOICE_ID=pMsXgVXv3BLzUgSXRplE
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Context / compaction (Nemotron Omni 256k default — see docs/CONTEXT.md)
# VLLM_MAX_MODEL_LEN=262144
# DISRUPTRON_CONTEXT_WINDOW=262144
# If OOM: VLLM_MAX_MODEL_LEN=131072 VLLM_GPU_UTIL=0.55
# DISRUPTRON_COMPACTION_RESERVE_TOKENS=4096
# DISRUPTRON_COMPACTION_KEEP_RECENT=8192
# DISRUPTRON_IMAGE_MAX_PX=768

# 24/7 heartbeat interval (OpenClaw agent config)
# DISRUPTRON_HEARTBEAT_EVERY=10m

# Nemotron Omni multimodal (audio + image via vLLM) — run: disruptron vllm --recreate
# VLLM_MULTIMODAL=1
# VLLM_MEDIA_DIR=/tmp/disruptron-media

# vLLM
# VLLM_IMAGE=vllm/vllm-openai:v0.20.0-aarch64-cu130-ubuntu2404
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_SERVED_MODEL=nemotron_3_nano_omni

# AI-Q deep research sidecar
# AIQ_SERVER_PORT=8001

# Google Calendar MCP (optional — ~/google-calendar-mcp, OAuth via npm run auth)
# DISRUPTRON_GOOGLE_CALENDAR=1
# GOOGLE_CALENDAR_MCP_DIR=~/google-calendar-mcp
# GOOGLE_CALENDAR_MCP_PORT=3000

# Disruptron delivery gateway + Telegram bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOW_FROM=
# DISRUPTRON_PUSH_PORT=8010
# DISRUPTRON_PUSH_HOST=127.0.0.1
# DISRUPTRON_PUSH_SECRET=
# Telegram bot + web chat gateway (disruptron-api)
# DISRUPTRON_BACKEND_URL=http://127.0.0.1:8010
# Upstream HTTP chat plug-in tried before agent fallback (auto mode)
# DISRUPTRON_BACKEND_CHAT_PATH=/v1/chat
# DISRUPTRON_CHAT_MODE=auto
# DISRUPTRON_AGENT_ID=disruptron
# DISRUPTRON_CONTEXT_DB=data/disruptron_context.db
# DISRUPTRON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Speech-to-text (disruptron-api POST /v1/transcribe)
# DISRUPTRON_STT_ENGINE=proxy
# DISRUPTRON_STT_URL=http://127.0.0.1:8000/v1/audio/transcriptions
# DISRUPTRON_STT_MODEL=whisper-1
# On-box Whisper: DISRUPTRON_STT_ENGINE=whisper and uv sync --extra stt in disruptron-api
# DISRUPTRON_STT_MODEL=base.en
# DISRUPTRON_STT_DEVICE=cuda

# TfL rate limits (optional)
# TFL_APP_KEY=

# Optional: HuggingFace token only if model download is gated
# HF_TOKEN=
