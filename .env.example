# NV-Disruptron — optional environment overrides

cp .env.example .env

# Required for voice alerts (hackathon sponsor)
ELEVENLABS_API_KEY=

# Optional voice selection (defaults via disruptron configure)
# ELEVENLABS_VOICE_ID=pMsXgVXv3BLzUgSXRplE
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Context / compaction (Nemotron Omni 256k default — see docs/CONTEXT.md)
# VLLM_MAX_MODEL_LEN=262144
# DISRUPTRON_CONTEXT_WINDOW=262144
# If OOM: VLLM_MAX_MODEL_LEN=131072 VLLM_GPU_UTIL=0.55
# DISRUPTRON_COMPACTION_RESERVE_TOKENS=4096
# DISRUPTRON_COMPACTION_KEEP_RECENT=8192
# DISRUPTRON_IMAGE_MAX_PX=768

# 24/7 heartbeat interval (OpenClaw agent config)
# DISRUPTRON_HEARTBEAT_EVERY=10m

# Nemotron Omni multimodal (audio + image via vLLM) — run: disruptron vllm --recreate
# VLLM_MULTIMODAL=1
# VLLM_MEDIA_DIR=/tmp/disruptron-media

# vLLM
# VLLM_IMAGE=vllm/vllm-openai:v0.20.0-aarch64-cu130-ubuntu2404
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_SERVED_MODEL=nemotron_3_nano_omni

# AI-Q deep research sidecar
# AIQ_SERVER_PORT=8001

# Telegram (optional proactive text alerts)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOW_FROM=

# TfL rate limits (optional)
# TFL_APP_KEY=
