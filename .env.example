# NV-Disruptron — optional environment overrides (no cloud API keys required)
#
# Copy if you want to customize paths:
#   cp .env.example .env

# Local vLLM (defaults work out of the box)
# VLLM_BASE_URL=http://127.0.0.1:8000/v1
# VLLM_SERVED_MODEL=nemotron_3_nano_omni

# Optional: higher TfL rate limits (anonymous access works without this)
# TFL_APP_KEY=

# Optional: HuggingFace token only if model download is gated
# HF_TOKEN=

# Disruptron Telegram bot (BotFather token — never commit .env)
# TELEGRAM_BOT_TOKEN=
# DISRUPTRON_PUSH_PORT=8010
# DISRUPTRON_PUSH_HOST=127.0.0.1
# DISRUPTRON_PUSH_SECRET=
