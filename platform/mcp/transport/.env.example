# TfL Unified API credentials
# Get your free key at: https://api-portal.tfl.gov.uk/
# 1. Sign up / Sign in
# 2. Go to Products → subscribe to "500 Requests per min" (free)
# 3. Copy the app_key from your Profile

# Optional — anonymous TfL access works without a key (~50 req/min)
# TFL_APP_KEY=your_tfl_app_key_here

# Optional: Some older examples still reference app_id, but it is no longer required.
# TFL_APP_ID=your_app_id_if_you_have_one
